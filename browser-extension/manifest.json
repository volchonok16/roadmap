{
  "manifest_version": 3,
  "name": "TFS Roadmap Bridge",
  "version": "1.0.0",
  "description": "Подключает сессию TFS (tfs.t2.ru) к локальному Roadmap без повторного входа.",
  "permissions": ["cookies", "tabs", "storage"],
  "host_permissions": [
    "https://tfs.t2.ru/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*"
  ],
  "action": {
    "default_title": "Подключить TFS к Roadmap",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:5173/*", "http://127.0.0.1:5173/*"],
      "js": ["content-roadmap.js"],
      "run_at": "document_start"
    }
  ]
}
