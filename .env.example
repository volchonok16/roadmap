# Минимальный .env — только настройки приложения. Авторизация в TFS — через UI (сессия браузера / PAT).

# Опционально: URL и проект по умолчанию для формы входа
TFS_BASE_URL=https://tfs.t2.ru/tfs/Main
TFS_PROJECT=Tele2
TFS_PROJECT_ID=c56fb5fe-9752-462a-82ae-0b9e10364510

# Опционально: PAT только для CI/скриптов (в браузере не нужен)
# TFS_PAT=
# Домен AD по умолчанию на форме входа (опционально)
# TFS_DEFAULT_DOMAIN=TELE2

# Production (см. deploy/DEPLOY.md и .env.production.example):
# APP_PUBLIC_URL=https://pallink.fun
# API_PUBLIC_URL=https://api.pallink.fun
# CORS_ALLOW_ORIGINS=https://pallink.fun,https://www.pallink.fun
# VITE_API_URL=https://api.pallink.fun

# --- ниже редко меняют; значения по умолчанию уже в config.py ---
# TFS_VERIFY_TLS=true
# TFS_BATCH_SIZE=100
# TFS_REQUEST_DELAY_SECONDS=0.2
# SYNC_STALE_RUNNING_MINUTES=180
# CHANGE_REQUEST_STATES=Express Analysis,Analysis Backlog,Analysis,Development,UAT,Pilot,Closed
